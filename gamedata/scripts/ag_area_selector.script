function UIAreaSelector:bullet_on_impact(bullet)
    local bullet_pos = bullet.position
    local wpn_id = bullet.weapon_id
    local p_id = bullet.parent_id
    local npc = get_unknown_object({id=p_id}, "game")
    local wpn = get_unknown_object({id=wpn_id}, "game")
    if not (npc and wpn) then return end
    if npc:id() ~= db.actor:id() then return end
    if not self:HasGizmos() then return end
    if self.gizmo_id == 2 then
        self:ShowGizmo(self.gizmo_id, false)
    end
    self:IncreaseGizmoID()
    self:SetGizmoPos(self.gizmo_id, bullet_pos)
    self:ShowGizmo(self.gizmo_id, true)
end

-- Helper
function UIAreaSelector:SetPosTrack(pos)
    dbg("dev", "setting pos track")
    self:SetPosTrackX(pos.x)
    self:SetPosTrackY(pos.y)
    self:SetPosTrackZ(pos.z)
end

function UIAreaSelector:SetPosTrackX(val)
    if not within_range(val, self.pos_min.x, self.pos_max.x) then return end
    self.prev_area_pos.x = self.curr_area_pos.x
    self.move_area["x"]["pos_track"]:SetFValue(val)
    self.curr_area_pos.x = val
end

