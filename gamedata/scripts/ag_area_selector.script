-- Move Area
function UIAreaSelector:OnEditPosBoxX()
    dbg("dev", "on edit x pos box")
    local new_pos_x = tonumber(self.move_area["x"]["pos_box"]:GetText())
    dbg("dev", "new pos x:%s", new_pos_x)
    if not within_range(new_pos_x, self.pos_min.x, self.pos_max.x) then
        dbg("dev", "resetting %s to %s as not with range [%s-%s]", new_pos_x, self.prev_area_pos.x, self.pos_min.x, self.pos_max.x)
        new_pos_x = self.curr_area_pos.x
    else
        dbg("dev", "using new pos")
        self.move_area["x"]["pos_track"]:SetFValue(tonumber(new_pos_x))
    end
    dbg("dev", "setting pos x from:%s to:%s", self.prev_area_pos.x, new_pos_x)
    self.prev_area_pos.x = self.curr_area_pos.x
    self.curr_area_pos.x = new_pos_x
    self.move_area["x"]["pos_box"]:SetText(tostring(round_idp(new_pos_x, 2)))
end

function UIAreaSelector:OnEditRotBoxX()
    local new_rot_x = tonumber(self.move_area["x"]["rot_box"]:GetText())
    if not within_range(new_rot_x, self.rot_min, self.rot_max) then
        new_rot_x = self.curr_area_rot.x
    else
        self.move_area["x"]["rot_track"]:SetFValue(tonumber(new_rot_x))
    end
    self.prev_area_rot.x = self.curr_area_rot.x
    self.curr_area_rot.x = new_rot_x
    self.move_area["x"]["rot_box"]:SetText(tostring(round_idp(new_rot_x, 2)))
end

