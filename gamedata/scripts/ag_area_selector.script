    self.vertices.H = vec_sub(center_pos, full_diagonal)
    self.vertices.B = vec_add(center_pos, full_opp_diagonal)
    self.vertices.G = vec_sub(center_pos, full_opp_diagonal)
    dbg("dev", "vertices:%s", self.vertices)
end

