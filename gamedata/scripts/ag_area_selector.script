    self.area_size["height"]["value_box"]:SetText(tostring(round_idp(val, 2)))
    self.prev_height = self.curr_height
    self.curr_height = val
end

function UIAreaSelector:SetWidth(val)
    self.area_size["width"]["value_track"]:SetFValue(val)
    self.area_size["width"]["value_box"]:SetText(tostring(round_idp(val, 2)))
    self.prev_width = self.curr_width
    self.curr_width = val
end

function UIAreaSelector:KillGizmos()
    self:HideGizmos()
    empty_table(self.corner_gizmos)
    empty_table(self.vert_gizmos)
    empty_table(self.face_gizmos)
end

function UIAreaSelector:ShowGizmos(state)
    dbg("dev", "setting gizmos to %s", state)
    self:ShowCornerGizmos(state)
    self:ShowVertGizmos(state)
    self:ShowFaceGizmos(state)
end

function UIAreaSelector:HideGizmos()
    self:ShowGizmos(false)
end

function UIAreaSelector:ShowCornerGizmos(state)
    self.corner_gizmos[1]["obj"].visible = state
    self.corner_gizmos[2]["obj"].visible = state
end

function UIAreaSelector:ShowVertGizmos(state)
    for id, _ in pairs(self.vert_gizmos) do
        self.vert_gizmos[id]["obj"].visible = state
    end
end

function UIAreaSelector:ShowFaceGizmos(state)
    for name, gizmo_tbl in pairs(self.face_gizmos) do
        self.face_gizmos[name][1].visible = state
        self.face_gizmos[name][2].visible = state
        self.face_gizmos[name][3].visible = state
        self.face_gizmos[name][4].visible = state
    end
end


-- HPB Vector
function UIAreaSelector:GetHeading(dir_vec, in_degrees)
    local heading = get_heading(dir_vec, in_degrees)
    if heading < self.rot_min then
        return heading + self.rot_max
    end
    return heading
end

function UIAreaSelector:GetPitch(dir_vec, in_degrees)
    local pitch = get_pitch(dir_vec, in_degrees)
    if pitch < self.rot_min then
        return pitch + self.rot_max
    end
    return pitch
end

function UIAreaSelector:GetBank(dir_vec, in_degrees)
    local bank = get_bank(dir_vec, in_degrees)
    if bank < self.rot_min then
        return bank + self.rot_max
    end
    return bank
end

function UIAreaSelector:HasGizmos()
    for i=1, 2 do
        self:HasGizmo(i)
    end
end

function UIAreaSelector:HasGizmo(idx)
    return contains(self.corner_gizmos, idx, true) 
        or contains(self.corner_gizmos[idx], "obj", true) 
end

function UIAreaSelector:SetGizmoPos(idx, pos)
    if not self:HasGizmo(idx) then return end
    local pos_mat = matrix():translate(pos)
    self.corner_gizmos[idx]["obj"].matrix = matrix():mul(pos_mat, self.gizmo_scale_mat)
end

function UIAreaSelector:ShowGizmo(idx, show)
    if not self:HasGizmo(idx) then return end
    self.corner_gizmos[idx]["obj"].visible = show
end

function UIAreaSelector:IncreaseGizmoID()
    self.gizmo_id = clamp(self.gizmo_id + 1, 1, 2)
end

function UIAreaSelector:ToggleDrawArea()
    self.draw_area = not self.draw_area
    self:ShowGizmos(self.draw_area)
end

function UIAreaSelector:FacesToID(face_a, face_b)
    return tonumber(strformat("%s%s", face_a, face_b), 32)
end

function UIAreaSelector:GetCenterPos()
    local dist = self.vertices.E:distance_to_sqr(self.vertices.D)
    local dir = vec_sub(self.vertices.D, self.vertices.E):normalize()
    return vec_set(self.vertices.E):mad(self.vertices.E, dir, dist / 2)
end

function rotate_diagonal(angle, axis, pos)
    local cos_a, sin_a = math.cos(angle), math.sin(angle)
    dbg("dev", "cos:%s, sin:%s",cos_a, sin_a)
    local w = vec_set(axis):normalize()
    dbg("dev", "w:%s", w)
    local align_vec = vec_set(VEC_X)
    if math.abs(vector():dotproduct(align_vec, w)) > 0.75 then
        align_vec = vec_set(VEC_Z)
    end
    dbg("dev", "align vec:%s", align_vec)
    local u = vector():crossproduct(align_vec, w)
    local v = vector():crossproduct(u, w)
    local lx = vector():dotproduct(pos, u)
    local ly = vector():dotproduct(pos, v)
    local lz = vector():dotproduct(pos, w)
    dbg("dev", "u:%s, v:%s, local|%s", u, v, vector():set(lx, ly, lz))
    -- irony huh
    local global_x = vec_set(u):mul(lx * cos_a - ly * sin_a)
    local global_y = vec_set(v):mul(lx * sin_a + ly * cos_a)
    local global_z = vec_set(w):mul(lz)
    dbg("dev", "global|%s, %s, %s", global_x, global_y, global_z)
    return vec_add(vec_add(global_x, global_y), global_z)
end

-- Callbacks
function on_key_press(dik)
    dbg("dev", "on key press:%s", hfg_utils.dik_to_str(dik))
    if dik == UI_KEY then
        start_ui()
    end
end


function on_option_change(options)
    setup_log(options["misc"]["debug_level"], LOG_HEADER, options["misc"]["enable_debug"])
    TOGGLE_UI_KEYBIND = options["main"]["toggle_ui_keybind"]
    QUIT_UI_KEYBIND = options["main"]["ui_quit_keybind"]
    dbg("debug", "Received options")
end

function on_game_start()
    RegisterScriptCallback("hfg_on_option_change", on_option_change)
    RegisterScriptCallback("on_key_press", on_key_press)
end
