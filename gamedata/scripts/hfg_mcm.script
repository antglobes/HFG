                id="siphon",
                sh=true,
                gr={
                    {id="title", type="slide", link="ui_options_slider_player", text="ui_mcm_hfg_title_siphon", size={512, 50}, spacing=20},
                    {id="activation_range", type="track", val=2, min=0.5, max=5, step=0.1, def=3},
