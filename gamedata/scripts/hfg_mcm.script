                    {id="title", type="slide", link="ui_options_slider_player", text="ui_mcm_hfg_title_breaker", size={512, 50}, spacing=20},
                    {id="toggle_panel_anim_style", type="list", val=0, def="Back", precondition={has_mcm_keybinds}, 
                        content={
                            {"Quadratic", "Quadratic"},
                            {"Cubic", "Cubic"},
                            {"Quartic", "Quartic"},
                            {"Quintic", "Quintic"},
                            {"Sine", "Sine"},
                            {"Circular", "Circular"},
                            {"Exponential", "Exponential"},
                            {"Elastic", "Elastic"},
