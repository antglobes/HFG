                    {id="max_fuel", type="track", val=2, min=0, max=100, step=1, def=60},
                    {id="max_power_output", type="track", val=2, min=0, max=100000, step=100, def=5000}, --1
                    {id="power_obj_search_radius", type="track", val=2, min=0, max=100, step=1, def=50},
                    {id="power_obj_broken_cond", type="track", val=2, min=0, max=1, step=0.1, def=0.1},
                    {id="toggle_ui_keybind", type="key_bind", val=2, def=DIK_keys.DIK_U, precondition={has_mcm_keybinds}},
