    main = {
        max_fuel = 60,
        max_power_output = 5000,
        power_obj_search_radius = 50,
        power_obj_broken_cond = 0.1,
        toggle_ui_keybind = DIK_keys.DIK_U,
        keybind_modifier = 1,
        keybind_mode = 0,
        key_trigger_time = 0.1,
        ui_quit_keybind = DIK_keys.DIK_ESCAPE,
    },
    blueprint = {
        toggle_preview_keybind = DIK_keys.DIK_P,
        toggle_preview_anim_style = "Bounce",
        toggle_preview_anim_duration = 3,
        scroll_up_keybind = DIK_keys.DIK_NUMPAD9,
        scroll_down_keybind = DIK_keys.DIK_NUMPAD6,
        scroll_step = 20,
        highlight_radius = 3,
    },
    breaker = {
        toggle_panel_anim_style = "Back",
        clr_selector_anim_style = "Quintic"
    },
    siphon = {
        activation_range = 3,
    },
    misc = {
        colour_blind_type = 1,
        enable_debug = false,
        debug_level = 1,
    },
}

LOG_HEADER = "[HFG|MCM]"

hfg_version = "0.13.12"
hfg_authors = "antglobes"
hfg_last_update = "08-11-25"
setup_init = false

local dbg_pr = nil
function setup_log(level, header, enabled)
    if not dbg_pr then
        dbg_pr = ag_logging.new({
            level=level,
            header=header,
            enabled=enabled
        })
    else
        dbg_pr:SetLevel(level)
        dbg_pr:Enable(enabled)
    end
end

function dbg(level, fmt, ...)
    if not dbg_pr then
        setup_log(get_config("misc", "debug_level"), LOG_HEADER, get_config("misc", "enable_debug"))    
    
    end
    dbg_pr:Log(level, fmt, ...)
end

function get_config(tab, key)
    local mcm_id = strformat("hfg/%s/%s", tab, key)
    if ui_mcm then 
        return ui_mcm.get(mcm_id) 
    end
    return defaults[tab][key]
end

function debugging_enabled()
	return get_config("misc", "enable_debug")
end

function has_mcm_keybinds()
    return ui_mcm and ui_mcm.key_hold
end

function on_mcm_load()
